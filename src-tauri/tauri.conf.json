{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenStack",
  "version": "0.1.0",
  "identifier": "com.burmjohn.tokenstack",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TokenStack",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "DeveloperTool",
    "shortDescription": "Read-only Codex usage command center.",
    "longDescription": "TokenStack imports local Codex history and read-only reset-credit snapshots without exposing auth secrets or mutating account state."
  }
}
